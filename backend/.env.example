# LifeOS V9 backend environment example
# Use these names in Render > Web Service > Environment.
# Do NOT commit real secrets.

FLASK_ENV=production
SECRET_KEY=
ALLOWED_ORIGINS=https://lifeos-v9-frontend.onrender.com

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Paste the complete Firebase service account JSON in one line in Render.
FIREBASE_CREDENTIALS_JSON=

GROQ_API_KEY=
AI_ONBOARDING_KEY=
AI_PLANNING_KEY=
AI_DAILY_KEY=

WEBHOOK_EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@lifeos.app
